<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.TextFlow?>

<BorderPane xmlns:fx="http://javafx.com"
            fx:controller="br.com.rhana.tcc.chatapp.client.ChatController"
            prefHeight="500.0" prefWidth="750.0">

   <padding>
      <Insets top="10" right="10" bottom="10" left="10"/>
   </padding>

   <left>
      <VBox spacing="5" prefWidth="180.0">
         <BorderPane.margin>
            <Insets right="10"/>
         </BorderPane.margin>
         <Label text="Usuários Online" style="-fx-font-weight: bold;"/>
         <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"/>
      </VBox>
   </left>

   <center>
      <VBox spacing="5">
         <Label text="Conversa" style="-fx-font-weight: bold;"/>
         <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                     style="-fx-background-color: transparent;">
            <TextFlow fx:id="chatAreaFlow" prefHeight="200.0" prefWidth="200.0">
               <padding>
                  <Insets top="5" right="5" bottom="5" left="5"/>
               </padding>
            </TextFlow>
         </ScrollPane>
      </VBox>
   </center>

   <bottom>
      <HBox spacing="10">
         <padding>
            <Insets top="10" bottom="0" left="0" right="0"/>
         </padding>
         <TextField fx:id="messageField"
                    promptText="Digite uma mensagem..."
                    HBox.hgrow="ALWAYS"
                    onAction="#sendMessage"
         />
         <Button text="Enviar"
                 onAction="#sendMessage"
                 prefWidth="80.0"/>
      </HBox>
   </bottom>
</BorderPane>